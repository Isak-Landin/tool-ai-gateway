# PostgreSQL database credentials
DATABASE_URL=postgresql://postgres:password123@AI-tool-gateway-db:5432/tool_gateway_db
POSTGRES_DB=tool_gateway_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123

# Container Port Configuration
UI_HOST=0.0.0.0
UI_PORT=4000
GATEWAY_PORT=4100

# Backend CORS
# Docker network URL for CORS origin - used by tool_gateway.py
LOCAL_SERVER_URL=http://AI-tool-gateway:4100

# AI Model & Tools (Docker Network URLs)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b
ARCHON_BASE_URL=http://archon:8181

# UI Flask Configuration
# How the UI container calls the gateway backend
GATEWAY_BASE_URL=http://AI-tool-gateway:4100
FLASK_SECRET_KEY=dev-secret-key-change-in-prod

# Feature Configuration
WEB_SEARCH_MAX_RESULTS=5
FILES_STORED_METHOD=git