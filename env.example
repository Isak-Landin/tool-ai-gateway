# PostgreSQL database credentials
DATABASE_URL=postgresql+psycopg://postgres:password123@ai-tool-gateway-db:5432/tool_gateway_db
POSTGRES_DB=tool_gateway_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123

# Container Port Configuration
UI_HOST=0.0.0.0
UI_PORT=4000
GATEWAY_PORT=4100
NGINX_PORT=3000

# Public hosts routed by the nginx ingress
UI_PUBLIC_HOST=tool-ui.isaklandin.com
API_PUBLIC_HOST=tool-api.isaklandin.com

# Backend CORS
# Comma-separated browser origins allowed to call the API from JavaScript.
# Use public UI origins here, not Docker-internal backend URLs.
CORS_ALLOWED_ORIGINS=http://localhost:4000,https://tool-ui.isaklandin.com,206.168.214.170

# AI Model & Tools (Docker Network URLs)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
ARCHON_BASE_URL=http://archon:8181

# UI FLASK CONFIGURATION
# How the UI container calls the gateway backend

# gateway can be replaced with public address too, if you run ui and api separately.
GATEWAY_URL=http://ai-tool-gateway:4100
UI_TRUSTED_HOSTS=localhost,127.0.0.1,tool-ui.isaklandin.com,www.tool-ui.isaklandin.com
FLASK_SECRET_KEY=dev-secret-key-change-in-prod
FLASK_DEBUG=true

# Host-mounted project storage root for the backend container bind mount
PROJECTS_HOST_ROOT=/mnt/tool-ai-gateway/projects

# Absolute in-container backend project storage root
PROJECTS_ROOT=/srv/tool-ai-gateway/projects

# Feature Configuration
WEB_SEARCH_MAX_RESULTS=5
FILES_STORED_METHOD=git
